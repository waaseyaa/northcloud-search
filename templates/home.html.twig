{% extends "base.html.twig" %}

{% block title %}North Cloud — Content Intelligence{% endblock %}

{% block styles %}
    .hero { padding: 80px 0 40px; text-align: center; }
    .hero h1 { font-size: 2.5rem; font-weight: 700; color: #f8fafc; margin-bottom: 8px; }
    .hero p { font-size: 1.1rem; color: #94a3b8; margin-bottom: 32px; }
    .hero .search-wrap { max-width: 600px; margin: 0 auto; }

    .topics { padding: 32px 0; }
    .topics-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b; margin-bottom: 12px; }
    .topic-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
    .topic-pill {
      display: inline-block; padding: 6px 16px;
      border: 1px solid #334155; border-radius: 9999px;
      font-size: 0.85rem; color: #cbd5e1;
      transition: border-color 0.2s, color 0.2s;
    }
    .topic-pill:hover { border-color: #38bdf8; color: #38bdf8; text-decoration: none; }

    .stories { padding: 40px 0; }
    .stories h2 { font-size: 1.3rem; font-weight: 600; color: #f8fafc; margin-bottom: 20px; }
    .story-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .story-card {
      background: #1e293b; border: 1px solid #334155; border-radius: 8px;
      padding: 20px; transition: border-color 0.2s;
    }
    .story-card:hover { border-color: #38bdf8; text-decoration: none; }
    .story-card h3 { font-size: 0.95rem; font-weight: 600; color: #f8fafc; margin-bottom: 6px; line-height: 1.4; }
    .story-card .meta { font-size: 0.8rem; color: #64748b; }
    .no-stories { color: #475569; text-align: center; padding: 40px 0; }
{% endblock %}

{% block body %}
<main>
  <section class="hero">
    <div class="container">
      <h1>North Cloud</h1>
      <p>Search across 100,000+ classified articles from Northern Ontario and beyond</p>
      <form action="/search" method="get" class="search-wrap">
        <input type="text" name="q" class="search-input" placeholder="Start typing to search..." autocomplete="off" id="search-input">
        <div class="suggest-dropdown" id="suggest-dropdown"></div>
      </form>
    </div>
  </section>

  <section class="topics">
    <div class="container" style="text-align: center;">
      <div class="topics-title">Trending Topics</div>
      <div class="topic-pills">
        {% for slug, label in topics %}
          <a href="/search?q=*&topics={{ slug }}" class="topic-pill">{{ label }}</a>
        {% endfor %}
      </div>
    </div>
  </section>

  {% if topStories is not empty %}
  <section class="stories">
    <div class="container">
      <h2>Top Stories</h2>
      <div class="story-grid">
        {% for story in topStories %}
        <a href="{{ story.url }}" target="_blank" rel="noopener" class="story-card">
          <h3>{{ story.title }}</h3>
          <div class="meta">{{ story.source_name|default('Unknown') }}{% if story.published_at %} &middot; {{ story.published_at }}{% endif %}</div>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% else %}
  <section class="stories">
    <div class="container">
      <div class="no-stories">Top stories will appear here once connected to the search API.</div>
    </div>
  </section>
  {% endif %}
</main>
{% endblock %}

{% block scripts %}
<script>
(function() {
  var input = document.getElementById('search-input');
  var dropdown = document.getElementById('suggest-dropdown');
  var timer = null;
  var activeIdx = -1;

  input.addEventListener('input', function() {
    clearTimeout(timer);
    var q = this.value.trim();
    if (q.length < 2) { dropdown.classList.remove('open'); return; }
    timer = setTimeout(function() { fetchSuggestions(q); }, 300);
  });

  input.addEventListener('keydown', function(e) {
    var items = dropdown.querySelectorAll('.suggest-item');
    if (e.key === 'ArrowDown') { e.preventDefault(); activeIdx = Math.min(activeIdx + 1, items.length - 1); highlight(items); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); activeIdx = Math.max(activeIdx - 1, 0); highlight(items); }
    else if (e.key === 'Enter' && activeIdx >= 0 && items[activeIdx]) { e.preventDefault(); window.location = '/search?q=' + encodeURIComponent(items[activeIdx].textContent); }
    else if (e.key === 'Escape') { dropdown.classList.remove('open'); activeIdx = -1; }
  });

  document.addEventListener('click', function(e) {
    if (!input.contains(e.target) && !dropdown.contains(e.target)) { dropdown.classList.remove('open'); }
  });

  function fetchSuggestions(q) {
    fetch('/api/suggest?q=' + encodeURIComponent(q))
      .then(function(r) { return r.json(); })
      .then(function(items) {
        if (!items.length) { dropdown.classList.remove('open'); return; }
        activeIdx = -1;
        while (dropdown.firstChild) { dropdown.removeChild(dropdown.firstChild); }
        items.forEach(function(suggestion) {
          var div = document.createElement('div');
          div.className = 'suggest-item';
          div.textContent = suggestion;
          div.addEventListener('click', function() {
            window.location = '/search?q=' + encodeURIComponent(suggestion);
          });
          dropdown.appendChild(div);
        });
        dropdown.classList.add('open');
      })
      .catch(function() { dropdown.classList.remove('open'); });
  }

  function highlight(items) {
    for (var i = 0; i < items.length; i++) {
      if (i === activeIdx) { items[i].classList.add('active'); }
      else { items[i].classList.remove('active'); }
    }
  }
})();
</script>
{% endblock %}
