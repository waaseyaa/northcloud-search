<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}North Cloud{% endblock %}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0f172a;
      color: #e2e8f0;
      line-height: 1.6;
    }

    a { color: #38bdf8; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 960px; margin: 0 auto; padding: 0 20px; }

    /* Header */
    .header { background: #1e293b; border-bottom: 1px solid #334155; padding: 12px 0; }
    .header .container { display: flex; align-items: center; gap: 24px; }
    .header-logo { font-size: 1.1rem; font-weight: 700; color: #f8fafc; }
    .header-nav { display: flex; gap: 16px; font-size: 0.85rem; }
    .header-nav a { color: #94a3b8; }
    .header-nav a:hover { color: #f8fafc; text-decoration: none; }

    /* Search box */
    .search-wrap { position: relative; }
    .search-input {
      width: 100%;
      padding: 12px 16px;
      font-size: 1rem;
      background: #1e293b;
      border: 1px solid #475569;
      border-radius: 8px;
      color: #f8fafc;
      outline: none;
    }
    .search-input:focus { border-color: #38bdf8; }
    .search-input::placeholder { color: #64748b; }

    /* Autocomplete dropdown */
    .suggest-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #1e293b;
      border: 1px solid #475569;
      border-top: none;
      border-radius: 0 0 8px 8px;
      z-index: 100;
      max-height: 300px;
      overflow-y: auto;
    }
    .suggest-dropdown.open { display: block; }
    .suggest-item {
      padding: 10px 16px;
      cursor: pointer;
      font-size: 0.9rem;
      color: #e2e8f0;
    }
    .suggest-item:hover, .suggest-item.active { background: #334155; }

    /* Footer */
    .footer { padding: 32px 0; border-top: 1px solid #1e293b; text-align: center; margin-top: 60px; }
    .footer p { font-size: 0.8rem; color: #475569; }

    {% block styles %}{% endblock %}
  </style>
</head>
<body>

<header class="header">
  <div class="container">
    <a href="/" class="header-logo">North Cloud</a>
    <nav class="header-nav">
      <a href="/">Home</a>
      <a href="/search">Search</a>
    </nav>
  </div>
</header>

{% block body %}{% endblock %}

<footer class="footer">
  <div class="container">
    <p>&copy; 2026 North Cloud &middot; Powered by <a href="https://waaseyaa.org">Waaseyaa</a></p>
  </div>
</footer>

{% block scripts %}{% endblock %}

</body>
</html>
